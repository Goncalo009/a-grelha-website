{
  "name": "a-grelha-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "verify:links": "node verify-links.mjs",
    "test:e2e": "playwright test",
    "test:mobile-clicks": "playwright test e2e/mobile-clicks.spec.ts",
    "verify": "npm run lint && npm run typecheck && npm run verify:links && npm run test:mobile-clicks"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "eslint-config-next": "^16.2.6",
    "lucide-react": "^0.400.0",
    "maplibre-gl": "^5.24.0",
    "next": "^16.2.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^2.2.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.0.0"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
