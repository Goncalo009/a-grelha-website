# Google Business Profile reviews
# Do not commit real values. Copy to .env.local and fill locally/deployment secrets.

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REFRESH_TOKEN=""

# Preferred: full resource name.
GOOGLE_BUSINESS_PROFILE_LOCATION_NAME="accounts/ACCOUNT_ID/locations/LOCATION_ID"

# Alternative if GOOGLE_BUSINESS_PROFILE_LOCATION_NAME is not set.
GOOGLE_BUSINESS_PROFILE_ACCOUNT_ID=""
GOOGLE_BUSINESS_PROFILE_LOCATION_ID=""

# Optional.
GOOGLE_REVIEWS_PAGE_SIZE="10"
GOOGLE_REVIEWS_ORDER_BY="updateTime desc"
